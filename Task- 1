import requests
import json
import os
import time
from datetime import datetime

# ── 1. Configuration ──────────────────────────────────────────────────────────

# Header tells the API who we are (good practice, avoids being blocked)
HEADERS = {"User-Agent": "TrendPulse/1.0"}

# HackerNews API base URL
BASE_URL = "https://hacker-news.firebaseio.com/v0"

# How many top story IDs to pull from HackerNews
MAX_IDS = 500

# Maximum stories to collect per category
MAX_PER_CATEGORY = 25

# Keywords used to classify each story into a category (case-insensitive match)
CATEGORY_KEYWORDS = {
    "technology"    : ["ai", "software", "tech", "code", "computer",
                       "data", "cloud", "api", "gpu", "llm"],
    "worldnews"     : ["war", "government", "country", "president",
                       "election", "climate", "attack", "global"],
    "sports"        : ["nfl", "nba", "fifa", "sport", "game",
                       "team", "player", "league", "championship"],
    "science"       : ["research", "study", "space", "physics",
                       "biology", "discovery", "nasa", "genome"],
    "entertainment" : ["movie", "film", "music", "netflix", "game",
                       "book", "show", "award", "streaming"],
}


# ── 2. Helper: Assign Category ────────────────────────────────────────────────

def assign_category(title):
    """
    Check the story title against each category's keyword list.
    Returns the first matching category name, or None if no match found.
    Comparison is case-insensitive so 'AI' matches 'ai'.
    """
    if not title:
        return None

    title_lower = title.lower()  # Normalise once, compare many times

    for category, keywords in CATEGORY_KEYWORDS.items():
        for keyword in keywords:
            if keyword in title_lower:
                return category  # Return the first category that matches

    return None  # Title didn't match any category keyword


# ── 3. Helper: Fetch a Single Story by ID ────────────────────────────────────

def fetch_story(story_id):
    """
    Fetch a single story's details from HackerNews using its ID.
    Returns the parsed JSON dict, or None if the request fails.
    We catch all exceptions so one bad story never crashes the whole script.
    """
    url = f"{BASE_URL}/item/{story_id}.json"

    try:
        response = requests.get(url, headers=HEADERS, timeout=10)
        response.raise_for_status()   # Raises an error for 4xx / 5xx responses
        return response.json()

    except requests.exceptions.Timeout:
        print(f"  ⚠ Timeout fetching story {story_id} — skipping.")
        return None

    except requests.exceptions.RequestException as e:
        print(f"  ⚠ Failed to fetch story {story_id}: {e} — skipping.")
        return None


# ── 4. Helper: Extract Required Fields ───────────────────────────────────────

def extract_fields(story, category):
    """
    Pull only the 7 required fields out of a raw HackerNews story object.
    'collected_at' is added by us — it records when we fetched the story.
    'descendants' (comment count) may be missing for stories with 0 comments.
    """
    return {
        "post_id"       : story.get("id"),
        "title"         : story.get("title", ""),
        "category"      : category,
        "score"         : story.get("score", 0),
        "num_comments"  : story.get("descendants", 0),   # 0 if key missing
        "author"        : story.get("by", "unknown"),
        "collected_at"  : datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    }


# ── 5. Step 1 — Fetch Top Story IDs ──────────────────────────────────────────

def fetch_top_story_ids():
    """
    Fetch the list of top story IDs from HackerNews.
    Returns the first MAX_IDS IDs as a list.
    """
    url = f"{BASE_URL}/topstories.json"
    print(f"Fetching top story IDs from: {url}")

    try:
        response = requests.get(url, headers=HEADERS, timeout=10)
        response.raise_for_status()
        all_ids = response.json()                  # Full list (often 500+)
        top_ids = all_ids[:MAX_IDS]                # Slice to first 500
        print(f"Retrieved {len(top_ids)} story IDs.\n")
        return top_ids

    except requests.exceptions.RequestException as e:
        print(f"✗ Could not fetch story IDs: {e}")
        return []


# ── 6. Step 2 — Fetch Story Details and Categorise ───────────────────────────

def collect_stories(story_ids):
    """
    Loop through story IDs, fetch each story's details, assign a category,
    and collect up to MAX_PER_CATEGORY (25) stories per category.

    A 2-second sleep is added once per category loop — not per story —
    to be polite to the API without slowing things down too much.
    """

    # Bucket to hold collected stories, one list per category
    categorised = {category: [] for category in CATEGORY_KEYWORDS}

    # Fetch all story details up front (we'll categorise as we go)
    print("Fetching individual story details...")
    stories_raw = []

    for story_id in story_ids:
        story = fetch_story(story_id)

        # Skip if fetch failed, story is None, or it's not a regular story
        if not story or story.get("type") != "story":
            continue

        # Skip stories with no title (can't categorise them)
        if not story.get("title"):
            continue

        stories_raw.append(story)

    print(f"Successfully fetched {len(stories_raw)} valid stories.\n")

    # ── Categorise and fill each bucket ──────────────────────────────────────
    for category in CATEGORY_KEYWORDS:
        print(f"Processing category: [{category.upper()}]")

        for story in stories_raw:
            # Stop once this category has 25 stories
            if len(categorised[category]) >= MAX_PER_CATEGORY:
                break

            assigned = assign_category(story.get("title", ""))

            # Only add to this bucket if it belongs here
            if assigned == category:
                record = extract_fields(story, category)
                categorised[category].append(record)

        count = len(categorised[category])
        print(f"  → Collected {count} stories for [{category}]")

        # 2-second pause between category processing loops (as required)
        time.sleep(2)

    # Flatten all category buckets into one list
    all_stories = []
    for category_stories in categorised.values():
        all_stories.extend(category_stories)

    return all_stories


# ── 7. Step 3 — Save to JSON File ─────────────────────────────────────────────

def save_to_json(stories):
    """
    Save the collected stories list to a JSON file inside the data/ folder.
    Creates the folder if it doesn't already exist.
    File is named with today's date: trends_YYYYMMDD.json
    """

    # Create data/ directory if it doesn't exist yet
    os.makedirs("data", exist_ok=True)

    # Build filename with today's date
    today     = datetime.now().strftime("%Y%m%d")
    filename  = f"data/trends_{today}.json"

    # Write stories to file with readable indentation
    with open(filename, "w", encoding="utf-8") as f:
        json.dump(stories, f, indent=4, ensure_ascii=False)

    print(f"\nCollected {len(stories)} stories. Saved to {filename}")
    return filename


# ── 8. Main Entrypoint ────────────────────────────────────────────────────────

def main():
    print("=" * 60)
    print("  TrendPulse — Task 1: HackerNews Data Collection")
    print("=" * 60)
    print()

    # Step 1: Get the top 500 story IDs
    story_ids = fetch_top_story_ids()
    if not story_ids:
        print("No story IDs retrieved. Exiting.")
        return

    # Step 2: Fetch story details and group into categories
    stories = collect_stories(story_ids)

    # Step 3: Save everything to a dated JSON file
    if stories:
        save_to_json(stories)
    else:
        print("No stories collected. Check your internet connection.")

    # ── Summary breakdown per category ───────────────────────────────────────
    print("\n── Category Breakdown ──────────────────────")
    category_counts = {}
    for story in stories:
        cat = story["category"]
        category_counts[cat] = category_counts.get(cat, 0) + 1

    for cat, count in category_counts.items():
        print(f"  {cat:<15} : {count} stories")

    print("=" * 60)
    print("  Done! Your JSON file is ready for Task 2.")
    print("=" * 60)


if __name__ == "__main__":
    main()
